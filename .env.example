# Contact Support Template
SENDGRID_CONTACT_SUPPORT_TEMPLATE_ID=
# Generic notification (post comment, comment reply, post like, comment like, inactivity reminder)
SENDGRID_GENERIC_NOTIFICATION_TEMPLATE_ID=

# Cron (optional: protect /api/cron/* routes)
# CRON_SECRET=

# HMAC secret for chapter check-in QR payloads (min 16 chars; use a long random string)
# CHECK_IN_QR_SECRET=
# Optional: reject QR codes older than this many seconds (omit for no TTL)
# CHECK_IN_QR_MAX_AGE_SEC=604800

# Telnyx API Key
TELNYX_API_KEY=
TELNYX_PHONE_NUMBER=
TELNYX_SANDBOX_MODE=

# Sentry Analytics Tracking
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# Linkedin OAuth
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=

# Crowded API (financial platform integration) — server-side only; use sandbox for dev
# https://sandbox-api.crowdedfinance.com — Bearer token (not X-API-Key)
CROWDED_API_BASE_URL=https://sandbox-api.crowdedfinance.com
# Optional: member-facing collect UI base (no trailing slash), e.g. https://staging.collect.crowdedme.xyz — enables “Collect page” links in Exec Admin Crowded overview.
# CROWDED_COLLECT_UI_BASE_URL=
CROWDED_API_TOKEN=
# Legacy alias — prefer CROWDED_API_TOKEN
# CROWDED_API_KEY=
# Optional: set to true to Zod-validate JSON responses (stricter)
# CROWDED_VALIDATE_RESPONSES=true
# Optional: log bulk contact sync / Crowded response shape to server console (may include emails; dev only)
# CROWDED_DEBUG_SYNC=true
# Optional: log Crowded dues checkout-link flow (listContacts → createIntent) and failed Crowded HTTP paths (dev only)
# CROWDED_DEBUG_CHECKOUT_LINK=true
# Optional: npm run test:crowded — Crowded API UUIDs for direct contact tests (not Trailblaize DB id)
# CROWDED_TEST_CHAPTER_ID=
# CROWDED_TEST_CONTACT_ID=
# Optional: TRA-561 — smoke-test DB mapping → listContacts (needs SUPABASE_SERVICE_ROLE_KEY)
# CROWDED_SMOKE_TRAILBLAIZE_CHAPTER_ID=

# Crowded webhooks (TRA-416) — same secret as Crowded subscription `data.secret`; verify HMAC-SHA256(raw body)
# CROWDED_WEBHOOK_SECRET=
# DANGEROUS: only for debugging if Crowded signature headers differ — never enable in production
# CROWDED_WEBHOOK_SKIP_SIGNATURE_VERIFY=false

